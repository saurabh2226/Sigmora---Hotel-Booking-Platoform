{
  "name": "hotel-booking-backend",
  "version": "1.0.0",
  "description": "Production-grade Hotel Booking Platform - Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "start:hybrid": "node src/server.js",
    "dev": "nodemon -L --watch src --ext js,json src/server.js",
    "dev:hybrid": "nodemon -L --watch src --ext js,json src/server.js",
    "seed": "npm run seed:mongo",
    "seed:mongo": "node src/utils/seedData.js",
    "seed:sql": "node src/utils/seedSqlFromMongo.js",
    "seed:all": "npm run seed:mongo && npm run seed:sql",
    "db:sync:sql": "node src/utils/syncSqlSchema.js",
    "test": "jest --coverage --detectOpenHandles --forceExit",
    "test:api": "jest tests/integration --detectOpenHandles --forceExit",
    "test:unit": "jest tests/unit --detectOpenHandles --forceExit",
    "test:integration": "jest tests/integration --detectOpenHandles --forceExit",
    "test:security": "jest tests/security --detectOpenHandles --forceExit",
    "test:coverage": "jest --coverage --detectOpenHandles --forceExit --coverageReporters=text --coverageReporters=lcov",
    "lint": "eslint src/ --ext .js"
  },
  "dependencies": {
    "@faker-js/faker": "^10.4.0",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^1.41.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.4",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "hpp": "^0.2.3",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.20.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.7",
    "razorpay": "^2.9.2",
    "redis": "^4.7.0",
    "sequelize": "^6.37.8",
    "slugify": "^1.6.6",
    "socket.io": "^4.7.2",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "mongodb-memory-server": "^9.1.4",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./tests/setup.js"
    ],
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/e2e/"
    ]
  }
}
